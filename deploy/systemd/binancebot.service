[Unit]
Description=BinanceBot trading iteration
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User=binancebot
Group=binancebot
# If the project is not in /opt/BinanceBot, update WorkingDirectory and ExecStart.
WorkingDirectory=/opt/BinanceBot
Environment=PYTHONIOENCODING=utf-8
ExecStart=/opt/BinanceBot/scripts/run_once.sh
TimeoutStartSec=120

[Install]
WantedBy=multi-user.target
