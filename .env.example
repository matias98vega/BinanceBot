BINANCE_API_KEY=
BINANCE_API_SECRET=

BINANCE_SPOT_BASE=https://api.binance.com
BINANCE_FUTURES_BASE=https://fapi.binance.com

STATE_FILE=trading/state.json
TRADES_LOG=trading/trades_log.txt
ANALYSIS_LOG=trading/analysis_log.txt
ANALYTICS_FILE=trading/trade_analytics.jsonl
DECISION_SNAPSHOTS_FILE=trading/decision_snapshots.jsonl
REPORTS_DIR=trading/reports
CSV_FILE=trading/reports/trades.csv
CYCLE_BASELINE_FILE=trading/.cycle_baseline.json

LOCK_FILE=/tmp/trading_bot.lock
ALERT_TARGET=

BOT_TOTAL_CAPITAL_LIMIT_USDT=50
# Deprecated: kept temporarily for existing guardrails. Prefer BOT_TOTAL_CAPITAL_LIMIT_USDT.
BOT_SPOT_CAPITAL_LIMIT_USDT=50
BOT_FUTURES_CAPITAL_LIMIT_USDT=25
BOT_MAX_POSITION_PERCENT=20
BOT_MAX_EXPOSURE_PERCENT=80
REBALANCE_MIN_WALLET_USDT=0
FUTURES_RESIDUAL_CLOSE_ENABLED=true
FUTURES_RESIDUAL_MAX_NOTIONAL_USDT=3.0
FUTURES_UNPROTECTED_BLOCK_NEW_ENTRIES=true

AUTO_CLEAN_DUST=false
DUST_CLEAN_DRY_RUN=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_ALERT_LEVEL=WARNING
TELEGRAM_ALERT_COOLDOWN_SECONDS=1800
TELEGRAM_NOTIFY_OPEN=true
TELEGRAM_NOTIFY_CLOSE=true
TELEGRAM_NOTIFY_TP=true
TELEGRAM_NOTIFY_SL=true
TELEGRAM_NOTIFY_PARTIAL=true
TELEGRAM_NOTIFY_REBALANCE=true
TELEGRAM_NOTIFY_BLACKLIST=false
TELEGRAM_NOTIFY_SNAPSHOT=false
TELEGRAM_NOTIFY_WARNING=true
TELEGRAM_NOTIFY_ERROR=true
TELEGRAM_NOTIFY_CRITICAL=true
